
### init auto-detects the trunk
$ git stack init
trunk(s): main
[exit 0]
stack.trunk: main

### init prefers the remote's default branch over main
$ git stack init
trunk(s): develop
[exit 0]
stack.trunk: develop

### init ignores the remote's default branch when it has no local ref
$ git stack init
trunk(s): main
[exit 0]
stack.trunk: main

### init dies when the remote's default branch is the only candidate
$ git stack init
error: cannot determine trunk branch; run 'git stack init <branch>'
[exit 1]
stack.trunk: 

### init records multiple trunks and lists them
$ git stack init main develop
trunk set to main, develop
[exit 0]
stack.trunk: main
develop
$ git stack init
trunk(s): main, develop
[exit 0]

### init rejects a non-existent trunk
$ git stack init nope
error: branch 'nope' does not exist
[exit 1]

### tree renders each trunk as its own root
$ git stack tree
  main (trunk)
    feat-a (1 commit(s))
  develop (trunk)
  * feat-d (1 commit(s))
[exit 0]

### restack stops at the secondary trunk it rests on
$ git stack restack
restacking stack rooted at feat-d
restacking feat-d onto develop
restacking feat-d2 onto feat-d
done.
[exit 0]
feat-d parent: develop
feat-d behind develop: 0
feat-d2 behind feat-d: 0

### version shows the program version
$ git stack version
git stack 0.1.0
[exit 0]

### global flags are parsed with optparse
$ git stack -v
git stack 0.1.0
[exit 0]
$ git stack --version
git stack 0.1.0
[exit 0]
$ git stack -h
git stack -- manage stacked branches with plain git

USAGE
    git stack <command> [args]

COMMANDS
    init [branch...]      Set (or auto-detect) the trunk branch(es).
    create <name>         Create <name> stacked on the current branch. (alias: b)
    tree                  Show the stack as a tree. (aliases: ls, list)
    up [child]            Check out the branch stacked on the current one.
    down                  Check out the current branch's parent.
    parent [branch]       Show or set the parent of the current branch.
    track [parent]        Track the current branch on top of [parent] (or trunk).
    untrack               Stop tracking the current branch in a stack.
    drop [branch]         Splice [branch] (or the current branch) out of the stack, reconnecting its children to its parent. (--delete also removes the branch)
    restack               Rebase the whole stack so each branch sits on its parent.
    sync                  Reparent branches whose parent was deleted (e.g. merged via a PR) onto trunk, then restack.
    version               Show the git-stack version and the Spinel build revision.
    help                  Show this help.

EXAMPLE
    git checkout main
    git stack create feature-a      # main -> feature-a
    git stack create feature-b      # feature-a -> feature-b
    git stack tree                  # inspect the stack
    # ... amend feature-a ...
    git stack restack               # replay feature-b on the new feature-a

Stack metadata is stored in git config: branch.<name>.stackParent (the
parent branch) and branch.<name>.stackBase (the commit the branch's own
work begins at, so restack can `git rebase --onto <parent> <base>` and
survive a parent that was squash-merged and deleted).
[exit 0]

### an unknown flag is rejected
$ git stack --bogus
error: invalid option: --bogus
[exit 1]

### create records the parent and checks out the branch
$ git stack create feat-a
created feat-a on top of main
[exit 0]
HEAD: feat-a
branch.feat-a.stackParent: main

### create rejects an existing branch
$ git stack create dup
error: branch 'dup' already exists
[exit 1]

### tree renders the whole stack
$ git stack tree
  main (trunk)
    feat-a (1 commit(s))
    * feat-b (1 commit(s))
[exit 0]

### down / up navigate the stack
$ git stack down
Switched to branch 'feat-a'
[exit 0]
HEAD: feat-a
$ git stack down
Switched to branch 'main'
[exit 0]
HEAD: main
$ git stack up
Switched to branch 'feat-b'
[exit 0]
HEAD: feat-b

### up with multiple children requires a choice
$ git stack up
'feat-a' has multiple children; pick one:
  git stack up feat-b
  git stack up feat-c
[exit 1]
$ git stack up feat-c
Switched to branch 'feat-c'
[exit 0]
HEAD: feat-c

### restack replays descendants onto the updated parent
$ git stack restack
restacking stack rooted at feat-a
restacking feat-b onto feat-a
done.
[exit 0]
feat-b behind feat-a: 0
feat-b contains a2: 1
HEAD: feat-b

### restack aborts cleanly on a conflict
$ git stack restack
restacking stack rooted at feat-a
restacking feat-b onto feat-a
error: conflict while rebasing 'feat-b' onto 'feat-a'.
Resolve it manually with:
    git checkout feat-b && git rebase --onto feat-a 74bb18bafa0c345a53729c0ffced01a2dd511047
then re-run 'git stack restack'.
[exit 1]
rebase in progress: 0

### parent shows and sets the parent
$ git stack parent
feat-a
[exit 0]
$ git stack parent other
parent of 'feat-b' set to 'other'
[exit 0]
branch.feat-b.stackParent: other

### untrack removes the metadata
$ git stack untrack
'feat-a' is no longer tracked in a stack
[exit 0]
branch.feat-a.stackParent: 

### drop splices the bottom branch out, reparenting children onto trunk
$ git stack drop feat-a
dropped feat-a; reparented children onto main
[exit 0]
feat-a stackParent (untracked): 
feat-a still exists: yes
feat-b stackParent: main
feat-b behind main: 0
feat-c stackParent: feat-b
HEAD: main

### drop a middle branch reconnects children to the grandparent
$ git stack drop feat-b
dropped feat-b; reparented children onto feat-a
[exit 0]
feat-c stackParent: feat-a
feat-b stackParent (untracked): 
HEAD: feat-a

### drop reparents every child of a branch with multiple children
$ git stack drop feat-a
dropped feat-a; reparented children onto main
[exit 0]
feat-b stackParent: main
feat-c stackParent: main

### drop --delete removes the branch ref after splicing
$ git stack drop feat-a --delete
dropped feat-a; reparented children onto main
deleted branch feat-a
[exit 0]
feat-a exists: no
feat-b stackParent: main
HEAD: main

### drop refuses a trunk and a non-existent branch
$ git stack drop main
error: cannot drop trunk 'main'
[exit 1]
$ git stack drop nope
error: branch 'nope' does not exist
[exit 1]

### drop with no argument splices the current branch
$ git stack drop
dropped feat-a; reparented children onto main
[exit 0]
feat-a stackParent (untracked): 
feat-b stackParent: main
HEAD: feat-a

### parent rejects an indirect cycle
$ git stack parent feat-b
error: 'feat-b' is downstream of 'feat-a'; setting it as parent would create a cycle
[exit 1]
branch.feat-a.stackParent: main

### track rejects an indirect cycle
$ git stack track feat-b
error: 'feat-b' is downstream of 'feat-a'; tracking it would create a cycle
[exit 1]

### restack leaves an untracked branch alone
$ git stack restack
restacking stack rooted at feat-a
done.
[exit 0]
HEAD: feat-a

### sync reparents an orphaned branch onto trunk and restacks it
$ git stack sync
syncing stack rooted at feat-b
'feat-b': parent 'feat-a' no longer exists; reparenting onto trunk 'main'
done.
[exit 0]
branch.feat-b.stackParent: main
feat-b behind main: 0
HEAD: feat-b

### sync heals a multi-level orphan chain in one pass
$ git stack sync
syncing stack rooted at feat-c
'feat-c': parent 'feat-b' no longer exists; reparenting onto trunk 'main'
done.
[exit 0]
branch.feat-c.stackParent: main
feat-c behind main: 0

### sync reports a conflict the same way restack does
$ git stack sync
syncing stack rooted at feat-b
'feat-b': parent 'feat-a' no longer exists; reparenting onto trunk 'main'
restacking feat-b onto main
error: conflict while rebasing 'feat-b' onto 'main'.
Resolve it manually with:
    git checkout feat-b && git rebase --onto main 74bb18bafa0c345a53729c0ffced01a2dd511047
then re-run 'git stack sync'.
[exit 1]

### tree shows a branch whose parent was deleted, then sync fixes it
$ git stack tree
  main (trunk)
  * feat-b (parent 'feat-a' missing; run `git stack sync`)
[exit 0]
$ git stack tree
  main (trunk)
  * feat-b (1 commit(s))
[exit 0]

### sync recovers a branch whose parent was squash-merged and deleted
$ git stack sync
syncing stack rooted at feature-b
'feature-b': parent 'feature-a' no longer exists; reparenting onto trunk 'main'
restacking feature-b onto main
done.
[exit 0]
feature-b stackParent: main
feature-b behind main: 0
feature-b commits above main: 1
feature-b contains a1: 0
feature-b contains a2: 0
feature-b contains b1: 1
feature-b stackBase == main tip: yes

### sync fast-forwards a branch fully merged into its parent
$ git stack sync
syncing stack rooted at feat-a
fast-forwarding feat-a to main
done.
[exit 0]
feat-a behind main: 0
feat-a commits above main: 0
feat-a stackBase == main tip: yes
HEAD: feat-a

### restack falls back to merge-base when stackBase is unrecorded
$ git stack restack
restacking stack rooted at feat-a
restacking feat-b onto feat-a
done.
[exit 0]
feat-b behind feat-a: 0
feat-b commits above feat-a: 1
feat-b contains a2: 1
feat-b contains b1: 1
feat-b stackBase == feat-a tip (re-recorded): yes

### sync clamps a stale stackBase to the merge-base instead of re-applying parent commits
$ git stack sync
syncing stack rooted at feat-a
restacking feat-b onto feat-a
done.
[exit 0]
feat-b behind feat-a: 0
feat-b commits above feat-a: 1
feat-b contains b1: 1
feat-b contains s3: 1
feat-b stackBase == feat-a tip (re-anchored): yes
